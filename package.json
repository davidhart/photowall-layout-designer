{
  "name": "photowall-layout-designer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-based, fully client-side photo wall (gallery wall) layout designer. Ships as a single static HTML file.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^2.1.0"
  }
}
